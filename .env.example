# Backend authentication and security defaults
# Copy this file to .env and replace placeholders with secure values.

# Keep auth enabled
BACKEND_AUTH_ENABLED=1

# JWT signing key (use a long random string in production)
BACKEND_AUTH_SECRET=replace-with-a-long-random-secret

# Admin bootstrap account used when users table is empty
BACKEND_ADMIN_USERNAME=admin
BACKEND_ADMIN_PASSWORD=change-this-password

# Token lifetime in minutes
BACKEND_AUTH_TOKEN_EXPIRE_MINUTES=480

# Disable legacy API-key auth once frontend is migrated to login tokens
BACKEND_AUTH_ALLOW_LEGACY_API_KEY=0

# Optional legacy key fallback (only needed when legacy mode is enabled)
BACKEND_API_KEY=devkey

# CORS allow-list for frontend origins (comma-separated)
DEV_ALLOW_ORIGINS=https://marketview1.netlify.app,http://localhost:5173
